# Kakao Developers 앱 정보
KAKAO_REST_API_KEY=여기에_카카오_REST_API_KEY
KAKAO_CLIENT_SECRET=여기에_카카오_CLIENT_SECRET
KAKAO_REDIRECT_URI=http://localhost:5000/oauth/kakao/callback
KAKAO_SCOPES=talk_message

# 날씨 기준 위치
LOCATION_QUERY=Seoul, Korea
TIMEZONE=Asia/Seoul
RUN_HOUR=7
RUN_MINUTE=0

# 웹서버
APP_HOST=0.0.0.0
APP_PORT=5000
DEBUG=false

# 토큰 저장 파일
TOKENS_FILE=tokens.json
